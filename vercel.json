{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    },
    {
      "src": "safebuild-xr/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/input_code",
      "dest": "/app.py"
    },
    {
      "src": "/",
      "dest": "/safebuild-xr/dist/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/safebuild-xr/dist/$1"
    }
  ]
}
